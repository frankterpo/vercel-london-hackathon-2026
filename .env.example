# Copy to .env and fill. Never commit .env.

# Alpic management / deploy APIs (GPT connector ops)
ALPIC_API_KEY=

# Optional: public URL used when the server calls itself for MCP (`/api/chat` → `/api/mcp`).
# On Vercel, VERCEL_URL is usually enough. Set this if you use a stable custom domain.
# APP_ORIGIN=https://your-project.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Skip merging Streamable MCP tools into chat (REST-only `vercelTools`).
# VERCEL_DISABLE_LOCAL_MCP=true

# Vercel REST tools (`lib/tools.ts` → api.vercel.com)
VERCEL_API_TOKEN=
# Optional: team-scoped API calls
# VERCEL_TEAM_ID=

# Copilot + drawing coach (default): AI SDK routes via Vercel AI Gateway (`anthropic/...`).
# Dashboard: finish AI onboarding / billing per team docs. Redeploy after changing env vars.
#
# Drawing coach vision order:
# ANTHROPIC_API_KEY → OPENAI_API_KEY → Vercel AI Gateway → OpenCode Zen (Zen Claude `/v1/messages`, vision-capable).
#
# Direct Anthropic (preferred when set)
# ANTHROPIC_API_KEY=
# Or coach-only Anthropic secret (won’t route other app features unless you reuse it)
# DRAWING_COACH_ANTHROPIC_API_KEY=
# DRAWING_COACH_ANTHROPIC_MODEL=
#
# Direct OpenAI vision fallback (`gpt-4o-mini` by default)
# OPENAI_API_KEY=
# DRAWING_COACH_OPENAI_API_KEY=
# DRAWING_COACH_OPENAI_MODEL=
#
# OpenCode Zen (after Gateway fails)—https://dev.opencode.ai/docs/zen/
# Claude via Anthropic-compatible Messages API (supports sketch images; billed per Zen).
# OPENCODE_API_KEY=
# Optional aliases: DRAWING_COACH_OPENCODE_API_KEY, OPEN_CODE_API_KEY
# DRAWING_COACH_ZEN_ANTHROPIC_MODEL=claude-sonnet-4
# Optional alias for the same value: DRAWING_COACH_ZEN_MODEL=

# Mubit persistent memory (canvas checkpoints + recall)
MUBIT_API_KEY=
# Optional: https://api.mubit.ai (default) or self-hosted / local proxy
MUBIT_ENDPOINT=
# Default http (Next.js-safe). Avoid `auto`/`grpc`: gRPC triggers readFileSync errors in Turbopack/Next.
# MUBIT_TRANSPORT=http
# Bright Data — Web Unlocker zone for POST https://api.brightdata.com/request
# (Drawing coach fetches a Google Images JSON URL through your zone.)
#
# Fastest local setup (creates zones like `cli_unlocker` + stores API key):
#   pnpm brightdata:login
#   pnpm brightdata:print-env
# Copy the printed lines into this file. Docs: https://docs.brightdata.com/cli/overview
BRIGHTDATA_API_KEY=
# Primary zone name (Web Unlocker product in Bright Data UI).
BRIGHTDATA_ZONE=
# Optional: match @brightdata/cli env names (we also read these if BRIGHTDATA_ZONE is empty)
# BRIGHTDATA_UNLOCKER_ZONE=
# BRIGHTDATA_SERP_ZONE=
