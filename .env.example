# Copy to .env and fill. Never commit .env.

# Alpic management / deploy APIs (GPT connector ops)
ALPIC_API_KEY=

# Optional: public URL used when the server calls itself for MCP (`/api/chat` → `/api/mcp`).
# On Vercel, VERCEL_URL is usually enough. Set this if you use a stable custom domain.
# APP_ORIGIN=https://your-project.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Skip merging Streamable MCP tools into chat (REST-only `vercelTools`).
# VERCEL_DISABLE_LOCAL_MCP=true

# Vercel REST tools (`lib/tools.ts` → api.vercel.com)
VERCEL_API_TOKEN=
# Optional: team-scoped API calls
# VERCEL_TEAM_ID=

# Mubit persistent memory (canvas checkpoints + recall)
MUBIT_API_KEY=
# Optional: https://api.mubit.ai (default) or self-hosted / local proxy
MUBIT_ENDPOINT=
# Optional: auto | http | grpc
MUBIT_TRANSPORT=

# Bright Data — Web Unlocker zone for POST https://api.brightdata.com/request
# (Drawing coach fetches a Google Images JSON URL through your zone.)
#
# Fastest local setup (creates zones like `cli_unlocker` + stores API key):
#   pnpm brightdata:login
#   pnpm brightdata:print-env
# Copy the printed lines into this file. Docs: https://docs.brightdata.com/cli/overview
BRIGHTDATA_API_KEY=
# Primary zone name (Web Unlocker product in Bright Data UI).
BRIGHTDATA_ZONE=
# Optional: match @brightdata/cli env names (we also read these if BRIGHTDATA_ZONE is empty)
# BRIGHTDATA_UNLOCKER_ZONE=
# BRIGHTDATA_SERP_ZONE=
