# Copy to .env and fill. Never commit .env.

# Alpic management / deploy APIs (GPT connector ops)
ALPIC_API_KEY=

# Vercel REST tools (`lib/tools.ts` server routes)
VERCEL_API_TOKEN=

# Mubit persistent memory (canvas checkpoints + recall)
MUBIT_API_KEY=
# Optional: https://api.mubit.ai (default) or self-hosted / local proxy
MUBIT_ENDPOINT=
# Optional: auto | http | grpc
MUBIT_TRANSPORT=

# Bright Data — values from Bright Data dashboard (zones, API access)
# Docs: https://docs.brightdata.com/
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=
